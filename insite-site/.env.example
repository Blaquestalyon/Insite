# --- Web3Forms (email delivery) -------------------------------------------
# 1. Go to https://web3forms.com  →  enter info@insiteintegrativewellness.com  →  click "Create Access Key"
# 2. Confirm the verification email Web3Forms sends to info@insiteintegrativewellness.com
# 3. Paste the access key below. Emails will be delivered to that verified inbox.
WEB3FORMS_ACCESS_KEY=

# Optional: override the destination address shown in the email body. The
# canonical delivery address is whichever inbox you verified above.
OFFICE_EMAIL=info@insiteintegrativewellness.com

# --- Airtable (database) --------------------------------------------------
# 1. https://airtable.com  →  create a base named "Insite" with a table named "Appointments"
#    Columns (case-sensitive):
#      Name           (Single line text)
#      Email          (Email)
#      Phone          (Phone)
#      Service        (Single line text)
#      Message        (Long text)
#      SMS Consent    (Checkbox)
#      Submitted At   (Date — include time, ISO)
# 2. https://airtable.com/create/tokens  →  Create token
#    Scopes:  data.records:write
#    Access:  the "Insite" base
# 3. Find your Base ID at https://airtable.com/api  →  starts with "app..."
AIRTABLE_TOKEN=
AIRTABLE_BASE_ID=
AIRTABLE_TABLE=Appointments

# --- Local dev only --------------------------------------------------------
PORT=3000
